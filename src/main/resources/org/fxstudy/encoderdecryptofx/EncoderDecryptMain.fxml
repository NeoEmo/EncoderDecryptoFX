<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.fxstudy.encoderdecryptofx.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="welcomeText" textAlignment="CENTER" wrapText="true" />
    <Label fx:id="intro" textAlignment="CENTER" wrapText="true" />
    <Label fx:id="first" textAlignment="CENTER" wrapText="true" />
    <Label fx:id="second" textAlignment="CENTER" wrapText="true" />
    <Label fx:id="third" textAlignment="CENTER" wrapText="true" />
    <Label fx:id="labelCheckBox" textAlignment="CENTER" wrapText="true" />
    <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="25.0">
        <Button fx:id="one" onAction="#pressOne" text="1" />
        <Button fx:id="two" onAction="#pressTwo" text="2" />
        <Button fx:id="three" onAction="#pressThree" text="3" />
    </HBox>
   <CheckBox fx:id="DecryptBox" text="Decrypt" />
    <ChoiceBox fx:id="chooseLang" prefWidth="150.0">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="Русский" />
                <String fx:value="Английский" />
            </FXCollections>
        </items>
        <value>
            <String fx:value="Русский" />
        </value>
    </ChoiceBox>
</VBox>
